---
import ThemeToggle from "./ThemeToggle.astro"

const navItems = [
  {
    title: "Experience",
    label: "experiencia",
    url: "/#experiencia",
  },
  {
    title: "Projects",
    label: "proyectos",
    url: "/#proyectos",
  },
  {
    title: "About Me",
    label: "sobre-mi",
    url: "/#sobre-mi",
  },
  {
    title: "Contact",
    label: "contacto",
    url: "mailto:gonzabaldiviezo@gmail.com",
  },
  {
    title: "Playground",
    label: "playground",
    url: "/playground",
  },
]
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2 sm:mt-4 px-2 sm:px-0"
>
  <nav
    class="header-nav flex max-w-[calc(100vw-1rem)] flex-wrap justify-center items-center gap-x-1 gap-y-1 px-2 py-1 text-[0.72rem] sm:px-4 sm:py-1.5 sm:text-sm font-medium rounded-full text-gray-600 dark:text-gray-300 border border-transparent"
  >
    {
      navItems.map((link) => (
        <a
          class:list={[
            "nav-link relative block whitespace-nowrap px-2.5 py-1 rounded-full transition-all duration-200 hover:text-yellow-500 dark:hover:text-yellow-400 sm:px-3 sm:py-1.5",
            link.label === "playground" &&
              "border border-yellow-400/20 bg-yellow-400/10 text-yellow-800 shadow-[0_0_18px_rgba(251,191,36,0.12)] dark:text-yellow-200 dark:shadow-[0_0_20px_rgba(251,191,36,0.14)]",
          ]}
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
    <div class="ml-1 pl-1 sm:ml-2 sm:pl-2 border-l border-gray-300/30 dark:border-white/10">
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = Array.from(document.querySelectorAll("[data-section]")) as HTMLElement[]
    const navItems = document.querySelectorAll("header nav a")
    let animationFrameId = 0

    const setActiveNav = (activeId: string | null) => {
      navItems.forEach((item) => {
        const isActive = activeId !== null && item.getAttribute("aria-label") === activeId

        item.classList.toggle("text-yellow-500", isActive)
        item.classList.toggle("dark:text-yellow-400", isActive)
        item.classList.toggle("bg-yellow-400/10", isActive)
        item.classList.toggle("text-gray-600", !isActive)
        item.classList.toggle("dark:text-gray-300", !isActive)
      })
    }

    const updateActiveNav = () => {
      const triggerLine = window.scrollY + window.innerHeight * 0.35
      const bottomThreshold = document.documentElement.scrollHeight - window.innerHeight - 96

      if (window.scrollY >= bottomThreshold) {
        setActiveNav("sobre-mi")
        return
      }

      let activeId: string | null = null

      sections.forEach((section) => {
        if (section.offsetTop <= triggerLine) {
          activeId = section.id
        }
      })

      setActiveNav(activeId)
    }

    const scheduleUpdate = () => {
      if (animationFrameId !== 0) {
        return
      }

      animationFrameId = window.requestAnimationFrame(() => {
        animationFrameId = 0
        updateActiveNav()
      })
    }

    window.addEventListener("scroll", scheduleUpdate, { passive: true })
    window.addEventListener("resize", scheduleUpdate)
    updateActiveNav()

    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        window.removeEventListener("scroll", scheduleUpdate)
        window.removeEventListener("resize", scheduleUpdate)
        if (animationFrameId !== 0) {
          window.cancelAnimationFrame(animationFrameId)
          animationFrameId = 0
        }
      } else {
        window.addEventListener("scroll", scheduleUpdate, { passive: true })
        window.addEventListener("resize", scheduleUpdate)
        updateActiveNav()
      }
    }
  })
</script>

<style>
  .header-nav {
    animation: nav-appear 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  .header-nav {
    @apply dark:bg-gray-900/80 bg-white/60;
  }

  .nav-link.text-yellow-500 {
    @apply font-semibold;
  }

  .nav-link[aria-label="playground"] {
    @apply ring-0;
  }

  .nav-link[aria-label="playground"]:hover {
    @apply shadow-[0_0_22px_rgba(251,191,36,0.16)];
  }

  @keyframes nav-appear {
    0% {
      @apply dark:bg-gray-900/0 bg-white/0 border-transparent shadow-none;
    }
    to {
      @apply shadow-lg ring-1 backdrop-blur-md ring-white/10 dark:ring-white/5 border-gray-200/20 dark:border-white/5;
    }
  }
</style>
