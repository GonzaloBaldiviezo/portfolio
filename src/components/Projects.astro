---
import GitHub from "./icons/GitHub.astro"
import Code from "./icons/Code.astro"
import JavaScript from "./icons/JavaScript.astro"
import NextJS from "./icons/NextJS.astro"
import Tailwind from "./icons/Tailwind.astro"
import TypeScript from "./icons/TypeScript.astro"
import K6 from "./icons/K6.astro"
import ExternalLink from "./icons/ExternalLink.astro"
import LinkButton from "./LinkButton.astro"
import projectsData from "@/data/projects.json"

const GITHUB_PROFILE_URL = "https://github.com/GonzaloBaldiviezo?tab=repositories"

const TAGS: Record<string, { name: string; class: string; icon: any }> = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  TYPESCRIPT: {
    name: "TypeScript",
    class: "bg-[#3178C6] text-white",
    icon: TypeScript,
  },
  JAVASCRIPT: {
    name: "JavaScript",
    class: "bg-[#F7DF1E] text-black",
    icon: JavaScript,
  },
  K6: {
    name: "k6",
    class: "bg-[#7D64FF] text-white",
    icon: K6,
  },
}

const DEFAULT_TAG = {
  name: "Tech",
  class: "bg-gray-700 text-white",
  icon: Code,
}

const PROJECTS = projectsData.map((project: (typeof projectsData)[number] & { link?: string }) => ({
  ...project,
  tags: project.tags.map((key) => TAGS[key] ?? DEFAULT_TAG),
}))
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
    <article class="flex flex-col space-x-0 space-y-6 group md:flex-row md:space-x-10 md:space-y-0">
  <div class="w-full md:w-1/2">
    <div class="relative aspect-video w-full overflow-hidden rounded-xl transition-all duration-500 ease-in-out transform shadow-xl md:group-hover:-translate-y-1 md:group-hover:shadow-[0_20px_60px_-10px_rgba(251,191,36,0.2)] lg:border lg:border-gray-800 lg:hover:border-yellow-400/30 lg:hover:bg-gray-800/50">
      <img alt={title} class="block h-full w-full object-cover object-center transition duration-500 md:scale-110 md:group-hover:scale-105" loading="lazy" src={image} />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg flex flex-col justify-center">
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      {title}
    </h3>
    <ul class="flex flex-row flex-wrap mt-3 gap-2">
      {tags.map((tag) => (
        <li>
          <span
            class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2`}
          >
            <tag.icon class="size-4" />
            {tag.name}
          </span>
        </li>
      ))}
    </ul>

    <p class="mt-3 text-gray-700 dark:text-gray-400 text-pretty">{description}</p>
    <footer class="flex items-center mt-4 gap-x-4">
      {github && (
        <LinkButton href={github}>
          <GitHub class="size-5" />
          Code
        </LinkButton>
      )}
      {link && (
        <LinkButton href={link}>
          <ExternalLink class="size-4" />
          Preview
        </LinkButton>
      )}
    </footer>
  </div>
</article>
    ))
  }

  <div class="flex justify-center pt-2">
    <LinkButton href={GITHUB_PROFILE_URL}>
      <GitHub class="size-5" />
      See more on GitHub
    </LinkButton>
  </div>
</div>



